diff --git a/syscall.h b/syscall.h
index bc5f356..087b9a3 100644
--- a/syscall.h
+++ b/syscall.h
@@ -20,3 +20,6 @@
 #define SYS_link   19
 #define SYS_mkdir  20
 #define SYS_close  21
+#define SYS_sem_init 22
+#define SYS_sem_down 23
+#define SYS_sem_up   24
diff --git a/sysproc.c b/sysproc.c
index 0686d29..c4e56f7 100644
--- a/sysproc.c
+++ b/sysproc.c
@@ -7,6 +7,34 @@
 #include "mmu.h"
 #include "proc.h"
 
+int
+sys_sem_init(void)
+{
+  int id, val;
+  if(argint(0, &id) < 0 || argint(1, &val) < 0)
+    return -1;
+  sem_init(id, val);
+  return 0;
+}
+
+int
+sys_sem_down(void)
+{
+  int id;
+  if(argint(0, &id) < 0) return -1;
+  sem_down(id);
+  return 0;
+}
+
+int
+sys_sem_up(void)
+{
+  int id;
+  if(argint(0, &id) < 0) return -1;
+  sem_up(id);
+  return 0;
+}
+
 int
 sys_fork(void)
 {
diff --git a/testsem.c b/testsem.c
new file mode 100644
index 0000000..2458e6b
--- /dev/null
+++ b/testsem.c
@@ -0,0 +1,46 @@
+#include "types.h"
+#include "stat.h"
+#include "user.h"
+
+int main()
+{
+  int ret1, ret2;
+  int CHILDSEM=0;
+  int PARENTSEM=1;
+  
+  sem_init(CHILDSEM, 0);
+  sem_init(PARENTSEM, 0); 
+  
+  ret1 = fork();
+  if(ret1 == 0)
+    {
+      sem_down(CHILDSEM);
+      printf(1, "I am child 1\n");
+      sem_up(PARENTSEM);
+      exit();
+    }
+  else
+    {
+      ret2 = fork();
+      if(ret2 == 0)
+        {
+          sem_down(CHILDSEM);
+          printf(1, "I am child 2\n");
+          sem_up(PARENTSEM);
+          exit();
+        }
+      else {
+        sleep(2);
+        printf(1, "I am parent and I should print first\n");
+        sem_up(CHILDSEM);
+        sem_down(PARENTSEM);
+        printf(1, "Only one child has printed by now\n");
+        sem_up(CHILDSEM);
+        sem_down(PARENTSEM);
+        printf(1, "Both children have printed by now\n");
+        wait();
+        wait();
+        exit();
+      }
+    }
+}
\ No newline at end of file
