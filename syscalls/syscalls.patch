diff --git a/vm.c b/vm.c
index 7134cff..835e678 100644
--- a/vm.c
+++ b/vm.c
@@ -54,6 +54,28 @@ walkpgdir(pde_t *pgdir, const void *va, int alloc)
   return &pgtab[PTX(va)];
 }
 
+int usedvp(void) {
+  struct proc *p = myproc();
+  if(p == 0) return 0;
+  uint pages_for_sz = PGROUNDUP(p->sz) / PGSIZE; 
+  return (int)(pages_for_sz );
+}
+
+int usedpp(void) {
+  struct proc *p = myproc();
+  if(p == 0 || p->pgdir == 0) return 0;
+
+  pde_t *pgdir = p->pgdir;
+  int count = 0;
+  for(uint va = 0; va < KERNBASE; va += PGSIZE){
+    pte_t *pte = walkpgdir(pgdir, (char*)va, 0);
+    if(pte && (*pte & PTE_P)){
+      count++;
+    }
+  }
+  return count;
+}
+
 // Create PTEs for virtual addresses starting at va that refer to
 // physical addresses starting at pa. va and size might not
 // be page-aligned.
