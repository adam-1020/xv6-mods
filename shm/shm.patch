diff --git a/test.c b/test.c
new file mode 100644
index 0000000..196b73e
--- /dev/null
+++ b/test.c
@@ -0,0 +1,23 @@
+#include "types.h"
+#include "user.h"
+
+#define SHM_VA 0x40000000
+
+int
+main(void)
+{
+  shmget();
+
+  int *x = (int*)SHM_VA;
+
+  if (fork() == 0) {
+    shmget();
+    sleep(100);
+    printf(1,"child: %d\n", *x);
+  } else {
+    *x = 1234;
+    wait();
+  }
+
+  exit();
+}
