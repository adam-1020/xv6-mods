diff --git a/vm.c b/vm.c
index 7134cff..072e5d5 100644
--- a/vm.c
+++ b/vm.c
@@ -6,6 +6,7 @@
 #include "mmu.h"
 #include "proc.h"
 #include "elf.h"
+#include "spinlock.h"
 
 extern char data[];  // defined by kernel.ld
 pde_t *kpgdir;  // for use in scheduler()
@@ -79,6 +80,48 @@ mappages(pde_t *pgdir, void *va, uint size, uint pa, int perm)
   return 0;
 }
 
+// shared memory
+static char *shm_kaddr = 0;
+static int shm_refcount = 0;
+static struct spinlock shm_lock;
+
+void
+shminit(void)
+{
+  initlock(&shm_lock, "shm");
+}
+
+int
+shmget(void)
+{
+  struct proc *p = myproc();
+  pte_t *pte;
+
+  acquire(&shm_lock);
+  if(shm_kaddr == 0){
+    shm_kaddr = kalloc();
+    if(shm_kaddr == 0){
+      release(&shm_lock);
+      return -1;
+    }
+    memset(shm_kaddr, 0, PGSIZE); 
+  }
+  pte = walkpgdir(p->pgdir, (char*)SHMVA, 0);
+  if(pte && (*pte & PTE_P)){
+    release(&shm_lock);
+    return 0;
+  }
+
+  if(mappages(p->pgdir, (void*)SHMVA, PGSIZE, V2P(shm_kaddr), PTE_W|PTE_U) < 0){
+    release(&shm_lock); 
+    return -1;
+  }
+
+  shm_refcount++;
+  release(&shm_lock);
+  return 0;
+}
+
 // There is one page table per process, plus one that's used when
 // a CPU is not running any process (kpgdir). The kernel uses the
 // current process's page table during system calls and interrupts;
@@ -287,6 +330,20 @@ freevm(pde_t *pgdir)
 
   if(pgdir == 0)
     panic("freevm: no pgdir");
+
+  pte_t *pte;
+  pte = walkpgdir(pgdir, (char*)SHMVA, 0);
+  if(pte && (*pte & PTE_P)){
+    *pte = 0;
+    acquire(&shm_lock);
+    shm_refcount--;
+    if(shm_refcount == 0){
+      kfree(shm_kaddr);
+      shm_kaddr = 0;
+    }
+    release(&shm_lock);
+  }
+
   deallocuvm(pgdir, KERNBASE, 0);
   for(i = 0; i < NPDENTRIES; i++){
     if(pgdir[i] & PTE_P){
@@ -329,6 +386,18 @@ copyuvm(pde_t *pgdir, uint sz)
       panic("copyuvm: page not present");
     pa = PTE_ADDR(*pte);
     flags = PTE_FLAGS(*pte);
+
+    if(i == SHMVA){
+      acquire(&shm_lock);
+      shm_refcount++;
+      release(&shm_lock); 
+      
+      if(mappages(d, (void*)SHMVA, PGSIZE, pa, flags) < 0)
+        goto bad;
+
+      continue;
+    }
+
     if((mem = kalloc()) == 0)
       goto bad;
     memmove(mem, (char*)P2V(pa), PGSIZE);
